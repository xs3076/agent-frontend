# Web server URL (dev proxy only, not used in production build)
WEB_SERVER="http://127.0.0.1:8080"

# Backend type, e.g., java, python
# Used at build time for Umi route redirects
BACK_END="java"

# Default username for application login (runtime: APP_DEFAULT_USERNAME)
DEFAULT_USERNAME=saa

# Default password for application login (runtime: APP_DEFAULT_PASSWORD)
DEFAULT_PASSWORD=123456
